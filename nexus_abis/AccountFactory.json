                        },
                        "returns": {
                            "account": "The deployed SmartAccount proxy address."
                        }
                    },
                    "getAddress(address,uint256)": {
                        "details": "Used by the frontend to show the user their deposit address before deployment.",
                        "params": {
                            "owner": "The future owner of the account.",
                            "salt": "The unique salt used for deployment."
                        },
                        "returns": {
                            "_0": "The deterministic future address of the Smart Account."
                        }
