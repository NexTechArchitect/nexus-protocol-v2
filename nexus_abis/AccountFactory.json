                "methods": {
                    "constructor": {
                        "params": {
                            "_implementation": "The address of the deployed SmartAccount logic."
                        }
                    },
                    "createAccount(address,uint256)": {
                        "params": {
                            "owner": "The address that will own the Smart Account (from social login).",
